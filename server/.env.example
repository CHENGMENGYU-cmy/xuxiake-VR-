# MySQL 配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=xuxiake
DB_USER=root
DB_PASSWORD=root

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET=xuxiake-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# 服务端口
SERVER_PORT=3001

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# 上传目录
UPLOAD_DIR=./uploads
